# API
API_PORT=8001
JWT_SECRET=replace-this-with-a-strong-secret
SPEECH_SERVICE_URL=http://127.0.0.1:8002
DATA_STORE_MODE=memory
POSTGRES_URL=postgresql://postgres:postgres@127.0.0.1:5432/englishbuddy
REDIS_URL=redis://127.0.0.1:6379
LLM_STRATEGY=hybrid
LLM_TIMEOUT_MS=18000

# LLM Providers (OpenAI-compatible)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

QWEN_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen3-32b

# Speech Service
SPEECH_PROVIDER_MODE=hybrid
IFLYTEK_STT_APP_ID=
IFLYTEK_STT_API_KEY=
IFLYTEK_SCORE_APP_ID=
IFLYTEK_SCORE_API_KEY=
SIFLYTEK_CORE_API_KEY=
IFLYTEK_STT_URL=wss://iat-api.xfyun.cn/v2/iat
IFLYTEK_SCORE_URL=wss://ise-api.xfyun.cn/v2/open-ise
IFLYTEK_API_SECRET=
IFLYTEK_STT_API_SECRET=
IFLYTEK_SCORE_API_SECRET=
IFLYTEK_ISE_AUDIO_FIELD_MODE=data
QWEN_TTS_API_KEY=
QWEN_TTS_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_TTS_ENDPOINT=/audio/speech
QWEN_TTS_MODEL=qwen-tts-flash
QWEN_TTS_VOICE=Cherry

# Web
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8001
